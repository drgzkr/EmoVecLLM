# EmoVecLLM — runtime environment for a single cloud GPU pod (RunPod / Lambda / …)
# ---------------------------------------------------------------------------
# A cloud pod is NOT a SLURM cluster, so you don't use the .sbatch wrapper here —
# you run the CLI directly. Copy this file to `.env`, fill in the blanks, then:
#
#     set -a && source .env && set +a            # export everything
#     python scripts/generate_dataset.py                  # interactive
#     # or, fully head-less:
#     python scripts/generate_dataset.py --non-interactive
#
# `.env` itself is gitignored — only this example is tracked. Never commit keys.

# ── Secrets ────────────────────────────────────────────────────────────────
# Weights & Biases API key — copy from https://wandb.ai/authorize
WANDB_API_KEY=
# Hugging Face token — ONLY for gated models (Llama-3) or HF upload.
# Leave this COMMENTED unless you have one — an empty value breaks HF downloads.
# https://huggingface.co/settings/tokens
# HF_TOKEN=

# ── wandb run ──────────────────────────────────────────────────────────────
WANDB_PROJECT=emovecllm
WANDB_MODE=online            # set to `offline` if the pod has no internet (wandb sync later)
# WANDB_ENTITY=              # leave blank to use your personal wandb account

# ── Self-stopping pipeline runner (scripts/run.sh) ───────────────────────────
AUTO_STOP=1                  # stop the pod itself when the run finishes (saves a forgotten GPU)
STOP_MODE=stop               # stop (releases GPU, keeps volume) | remove (terminate the pod)
# MAX_RUNTIME_MIN=           # watchdog cap (minutes). Leave UNSET to use the profile
#                            # default (lite=10, full=240). Setting it here overrides
#                            # BOTH profiles — don't pin it to 10 or it'll kill full runs.
# RUNPOD_API_KEY=            # RunPod account API key (Settings → API Keys) — REQUIRED for self-stop
# RUNPOD_POD_ID is injected automatically by RunPod — don't set it.

# ── Results storage ─────────────────────────────────────────────────────────
# scripts/push_results.sh target: git (commit text dataset to this repo) or hf.
RESULTS_TARGET=git
# HF_DATASET_REPO=you/emovecllm-stories   # only for RESULTS_TARGET=hf

# ── Dataset generation (see scripts/generate_dataset.py for all knobs) ──────
# Clone the repo ONTO the persistent volume (e.g. /workspace/EmoVecLLM) and leave
# this blank → data/processed is both persistent AND tracked by the repo, so
# `push_results.sh` (git mode) can commit it directly.
EMOVEC_WORK_DIR=
EMOVEC_GENERATOR_MODEL=Qwen/Qwen2.5-7B-Instruct
EMOVEC_PRECISION=auto        # auto|bf16|fp16|4bit|8bit  (auto → 4bit under ~24GB)
EMOVEC_BATCH_SIZE=8
EMOVEC_MAX_JOBS=0            # 0 = all pending jobs
EMOVEC_BUILD_MANIFEST=1      # run nb02 to make prompts.jsonl if it's missing
# EMOVEC_SMOKE_TEST=1        # uncomment for a tiny wiring check before the full run
